        // Comprueba si la selección coincide con alguna palabra del listado
        function checkSelectionResult() {
            if (selectedCellsList.length === 0) return;

            // Extraer letras de la selección
            const stringSelected = selectedCellsList.map(cell => sopaGrid[cell.r][cell.c]).join('');
            const reversedString = stringSelected.split('').reverse().join('');

            let foundAny = false;

            sopaWords.forEach(wordObj => {
