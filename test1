                        if (gridCell) {
                            gridCell.className = "aspect-square flex items-center justify-center text-xs md:text-sm font-extrabold select-none bg-green-100 dark:bg-green-950/40 text-green-600 dark:text-green-400 border border-green-200 dark:border-green-900/40 rounded-lg cursor-pointer active:scale-95 transition-all shadow-sm animate-pop";
                        }
