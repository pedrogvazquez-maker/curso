        // ==========================================
        //  SISTEMA: GENERADOR DE SOPA DE LETRAS
        // ==========================================
        function buildSopaDeLetras(rawWords) {
            sopaWords = rawWords.map(w => ({ text: w.word, found: false, cells: [] }));
            
            // Inicializar matriz vacía
            sopaGrid = Array(currentGridSize).fill(null).map(() => Array(currentGridSize).fill(''));

            // Direcciones de colocación permitidas
            const easyDirections = [
                [0, 1],   // Derecha
                [1, 0],   // Abajo
            ];
            const hardDirections = [
                [0, 1],   // Derecha
                [1, 0],   // Abajo
                [1, 1],   // Diagonal Abajo-Derecha
                [-1, 1],  // Diagonal Arriba-Derecha
                [0, -1],  // Izquierda
                [-1, 0]   // Arriba
            ];

            const activeDirs = (currentDifficulty === 'easy') ? easyDirections : hardDirections;

            // Intentar acomodar cada una de las palabras en el tablero
            sopaWords.forEach(wordObj => {
                const text = wordObj.text;
                let placed = false;
                let attempts = 0;

                while (!placed && attempts < 150) {
                    attempts++;
                    const dir = activeDirs[Math.floor(Math.random() * activeDirs.length)];
                    const r = Math.floor(Math.random() * currentGridSize);
                    const c = Math.floor(Math.random() * currentGridSize);

                    if (canPlaceWordInSopa(text, r, c, dir)) {
                        const coordinates = placeWordInSopa(text, r, c, dir);
                        wordObj.cells = coordinates;
                        placed = true;
                    }
                }
            });

            // Rellenar casillas vacías con caracteres aleatorios del abecedario
            const alphabet = "ABCDEFGHIJKLMNÑOPQRSTUVWXYZ";
            for (let r = 0; r < currentGridSize; r++) {
                for (let c = 0; c < currentGridSize; c++) {
                    if (sopaGrid[r][c] === '') {
                        sopaGrid[r][c] = alphabet[Math.floor(Math.random() * alphabet.length)];
                    }
                }
            }

            // Dibujar tablero visual
            renderSopaGrid();
            renderSopaWordsList();
            document.getElementById('winBanner').classList.add('hidden');
        }

        function canPlaceWordInSopa(word, r, c, dir) {
            const len = word.length;
            const dr = dir[0];
            const dc = dir[1];

            // Comprobar desbordamientos
            const endRow = r + dr * (len - 1);
            const endCol = c + dc * (len - 1);

            if (endRow < 0 || endRow >= currentGridSize || endCol < 0 || endCol >= currentGridSize) {
                return false;
            }

            // Validar solapamiento permitido
            for (let i = 0; i < len; i++) {
                const currentCellChar = sopaGrid[r + dr * i][c + dc * i];
                if (currentCellChar !== '' && currentCellChar !== word[i]) {
                    return false;
                }
            }
            return true;
        }

        function placeWordInSopa(word, r, c, dir) {
            const len = word.length;
            const dr = dir[0];
            const dc = dir[1];
            const coords = [];

            for (let i = 0; i < len; i++) {
                const currR = r + dr * i;
                const currC = c + dc * i;
                sopaGrid[currR][currC] = word[i];
                coords.push({ r: currR, c: currC });
            }
            return coords;
        }

        function renderSopaGrid() {
            const container = document.getElementById('sopaGridContainer');
            container.innerHTML = '';
            
            // Ajustar columnas dinámicamente según Tailwind
            container.style.gridTemplateColumns = `repeat(${currentGridSize}, minmax(0, 1fr))`;

            for (let r = 0; r < currentGridSize; r++) {
                for (let c = 0; c < currentGridSize; c++) {
                    const cell = document.createElement('div');
                    cell.className = "aspect-square flex items-center justify-center text-xs md:text-sm font-extrabold select-none bg-white dark:bg-slate-900 border border-slate-200/40 dark:border-slate-800/60 rounded-lg text-slate-800 dark:text-slate-100 cursor-pointer active:scale-95 transition-all shadow-sm";
                    cell.dataset.row = r;
                    cell.dataset.col = c;
                    cell.textContent = sopaGrid[r][c];

                    // Eventos para Mouse
                    cell.addEventListener('mousedown', startSelectMouse);
                    cell.addEventListener('mouseenter', enterSelectMouse);
                    
                    // Eventos para Pantallas Táctiles (Móviles)
                    cell.addEventListener('touchstart', startSelectTouch, { passive: false });

                    container.appendChild(cell);
                }
            }

            // Terminar selección global del mouse
            window.addEventListener('mouseup', endSelectMouse);

            // Control táctil de movimiento en el contenedor
            container.addEventListener('touchmove', moveSelectTouch, { passive: false });
            container.addEventListener('touchend', endSelectTouch);
        }

