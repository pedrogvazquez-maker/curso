        // Soporte Táctil Móvil
        function startSelectTouch(e) {
            e.preventDefault();
            isSelecting = true;
            document.body.classList.add('no-scroll');
            
            const touch = e.touches[0];
            const target = document.elementFromPoint(touch.clientX, touch.clientY);
            const gridCell = target ? target.closest('[data-row]') : null;

            if (gridCell) {
                selectStartCell = {
                    r: parseInt(gridCell.dataset.row),
                    c: parseInt(gridCell.dataset.col)
                };
                selectEndCell = selectStartCell;
                highlightSelection();
            }
        }

        function moveSelectTouch(e) {
            if (!isSelecting) return;
            e.preventDefault();

            const touch = e.touches[0];
            const target = document.elementFromPoint(touch.clientX, touch.clientY);
            const gridCell = target ? target.closest('[data-row]') : null;

            if (gridCell) {
                const currRow = parseInt(gridCell.dataset.row);
                const currCol = parseInt(gridCell.dataset.col);
                
                if (selectEndCell.r !== currRow || selectEndCell.c !== currCol) {
                    selectEndCell = { r: currRow, c: currCol };
                    highlightSelection();
                }
            }
        }

        function endSelectTouch() {
            if (!isSelecting) return;
            isSelecting = false;
            document.body.classList.remove('no-scroll');
            checkSelectionResult();
            clearHighlights();
        }

        // Calcula el camino recto/diagonal entre el inicio y el fin seleccionado
        function calculateSelectionLine(start, end) {
            const cells = [];
            const dRow = end.r - start.r;
            const dCol = end.c - start.c;

            // Determinar tipo de dirección
            const absDR = Math.abs(dRow);
            const absDC = Math.abs(dCol);

            let steps = 0;
            let rStep = 0;
            let cStep = 0;

            if (dRow === 0 && dCol !== 0) { // Horizontal
                steps = absDC;
                cStep = dCol / absDC;
            } else if (dCol === 0 && dRow !== 0) { // Vertical
                steps = absDR;
                rStep = dRow / absDR;
            } else if (absDR === absDC && dRow !== 0) { // Diagonal exacta
                steps = absDR;
                rStep = dRow / absDR;
                cStep = dCol / absDC;
            } else {
                // No es línea recta o diagonal perfecta permitida
                return [start];
            }

            for (let i = 0; i <= steps; i++) {
                cells.push({
                    r: start.r + rStep * i,
                    c: start.c + cStep * i
                });
            }
            return cells;
        }

        // Resalta las celdas actualmente seleccionadas de forma translúcida
        function highlightSelection() {
            clearHighlights();
            selectedCellsList = calculateSelectionLine(selectStartCell, selectEndCell);

            selectedCellsList.forEach(cell => {
                const gridCell = document.querySelector(`[data-row="${cell.r}"][data-col="${cell.c}"]`);
                if (gridCell) {
                    // Si no es una celda verde ya descubierta, le damos estilo de selección temporal
                    if (!gridCell.classList.contains('text-green-600')) {
                        gridCell.classList.add('bg-blue-100', 'dark:bg-blue-900/50', 'text-blue-600', 'dark:text-blue-300', 'scale-95');
                    }
                }
            });
        }

        function clearHighlights() {
