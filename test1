        // ==========================================
        //  SISTEMA: GENERADOR DE CRUCIGRAMAS
        // ==========================================
        function buildCrucigrama(rawWords) {
            crosswordWords = rawWords.map(w => ({ word: w.word, clue: w.clue }));
            crosswordPlacements = [];
            
            // Inicializar matriz de datos para el crucigrama vacía
            crosswordGrid = Array(crosswordGridHeight).fill(null).map(() => 
                Array(crosswordGridWidth).fill(null).map(() => ({
                    char: '', r: 0, c: 0, black: true, number: '', acrossNum: null, downNum: null
                }))
            );

            // Ordenar las palabras de mayor a menor longitud para maximizar los cruces
            const sortedWords = [...crosswordWords].sort((a, b) => b.word.length - a.word.length);

            // 1. Colocar la primera palabra más larga en el centro horizontalmente
            const first = sortedWords.shift();
            const startR = Math.floor(crosswordGridHeight / 2);
            const startC = Math.max(0, Math.floor((crosswordGridWidth - first.word.length) / 2));
            
            placeWordInCrossword(first.word, first.clue, startR, startC, 'across', 1);

            // 2. Intentar colocar el resto de las palabras buscando intersecciones
            let nextNum = 2;
            sortedWords.forEach(item => {
                let placed = false;

                // Buscar intersecciones de letras entre la nueva palabra y lo ya colocado
                for (let placedWord of crosswordPlacements) {
                    for (let i = 0; i < placedWord.word.length; i++) {
                        const pChar = placedWord.word[i];
                        const pR = placedWord.dir === 'across' ? placedWord.r : placedWord.r + i;
                        const pC = placedWord.dir === 'across' ? placedWord.c + i : placedWord.c;

                        // Buscar coincidencia de letra en la nueva palabra
                        for (let j = 0; j < item.word.length; j++) {
                            if (item.word[j] === pChar) {
                                // Determinar dirección opuesta a la palabra cruzada
                                const nextDir = placedWord.dir === 'across' ? 'down' : 'across';
                                const targetR = nextDir === 'down' ? pR - j : pR;
                                const targetC = nextDir === 'down' ? pC : pC - j;

                                if (canPlaceWordInCrossword(item.word, targetR, targetC, nextDir)) {
                                    placeWordInCrossword(item.word, item.clue, targetR, targetC, nextDir, nextNum++);
                                    placed = true;
                                    break;
                                }
                            }
                        }
                        if (placed) break;
                    }
                    if (placed) break;
                }
            });

            // Reorganizar y renderizar
            renderCrosswordGrid();
            renderCrosswordClues();
            document.getElementById('crosswordWinBanner').classList.add('hidden');
        }

        function canPlaceWordInCrossword(word, r, c, dir) {
            const len = word.length;
            const isAcross = dir === 'across';

            // Validar límites
            if (r < 0 || c < 0 || (isAcross && c + len > crosswordGridWidth) || (!isAcross && r + len > crosswordGridHeight)) {
                return false;
            }

            // Comprobar espacios vacíos y colindantes
            for (let i = 0; i < len; i++) {
                const currR = isAcross ? r : r + i;
                const currC = isAcross ? c + i : c;
                const cell = crosswordGrid[currR][currC];

                // Si la casilla no está vacía y tiene una letra diferente
                if (!cell.black && cell.char !== word[i]) {
                    return false;
                }

                // Asegurar que no "pegue" de forma paralela a otra palabra (reglas del crucigrama clásico)
                if (cell.black) {
                    if (isAcross) {
                        // Revisar arriba/abajo
                        if ((currR > 0 && !crosswordGrid[currR - 1][currC].black && crosswordGrid[currR - 1][currC].char !== '') ||
                            (currR < crosswordGridHeight - 1 && !crosswordGrid[currR + 1][currC].black && crosswordGrid[currR + 1][currC].char !== '')) {
                            // Excepto si es el punto de cruce de letra (pero aquí cell.black es true, por lo tanto no es un cruce)
                            return false;
                        }
                    } else {
                        // Revisar izquierda/derecha
                        if ((currC > 0 && !crosswordGrid[currR][currC - 1].black && crosswordGrid[currR][currC - 1].char !== '') ||
                            (currC < crosswordGridWidth - 1 && !crosswordGrid[currR][currC + 1].black && crosswordGrid[currR][currC + 1].char !== '')) {
                            return false;
                        }
                    }
                }
            }

            // Comprobar extremos adyacentes (casillas inmediatamente anterior y posterior a la palabra)
            if (isAcross) {
                if (c > 0 && !crosswordGrid[r][c - 1].black) return false;
                if (c + len < crosswordGridWidth && !crosswordGrid[r][c + len].black) return false;
            } else {
                if (r > 0 && !crosswordGrid[r - 1][c].black) return false;
                if (r + len < crosswordGridHeight && !crosswordGrid[r + len][c].black) return false;
            }

            return true;
        }

        function placeWordInCrossword(word, clue, r, c, dir, num) {
            const len = word.length;
            const isAcross = dir === 'across';

            // Registrar colocación
            crosswordPlacements.push({ word, clue, r, c, dir, num });

            // Rellenar cuadrícula física
            for (let i = 0; i < len; i++) {
                const currR = isAcross ? r : r + i;
                const currC = isAcross ? c + i : c;
                
                const cell = crosswordGrid[currR][currC];
                cell.black = false;
                cell.char = word[i];
                cell.r = currR;
                cell.c = currC;

                // Añadir el número de pista solo al primer carácter de la palabra
                if (i === 0) {
                    cell.number = num;
                }
            }
        }

        function renderCrosswordGrid() {
            const container = document.getElementById('crucigramaGridContainer');
            container.innerHTML = '';

            container.style.gridTemplateColumns = `repeat(${crosswordGridWidth}, minmax(0, 1fr))`;

            for (let r = 0; r < crosswordGridHeight; r++) {
                for (let c = 0; c < crosswordGridWidth; c++) {
                    const cellData = crosswordGrid[r][c];
                    const cell = document.createElement('div');

                    if (cellData.black) {
                        cell.className = "aspect-square bg-slate-900 dark:bg-slate-950 border border-slate-800 rounded-md shadow-inner";
                    } else {
                        cell.className = "aspect-square bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-700 rounded-md relative flex items-center justify-center";
                        
                        // Agregar número identificador si existe
                        if (cellData.number) {
                            const numSpan = document.createElement('span');
                            numSpan.className = "absolute top-0.5 left-1 text-[8px] font-extrabold text-slate-400 dark:text-slate-500";
                            numSpan.textContent = cellData.number;
                            cell.appendChild(numSpan);
                        }

                        // Agregar entrada de letra interactiva
                        const input = document.createElement('input');
                        input.type = 'text';
                        input.maxLength = 1;
                        input.className = "w-full h-full text-center text-xs md:text-sm font-extrabold uppercase bg-transparent text-slate-800 dark:text-slate-100 focus:outline-none focus:bg-amber-50 dark:focus:bg-amber-950/30 rounded-md pt-2 select-all";
                        input.dataset.r = r;
                        input.dataset.c = c;
                        
                        // Validación de victoria al cambiar
                        input.addEventListener('input', (e) => {
                            e.target.value = e.target.value.toUpperCase().replace(/[^A-ZÑ]/g, '');
                            validateSingleCell(input, r, c);
                            checkCrosswordWin();
                        });

                        // Navegación por teclado cómoda
                        input.addEventListener('keydown', (e) => {
                            navigateCrosswordKey(e, r, c);
                        });

                        cell.appendChild(input);
                    }
                    container.appendChild(cell);
                }
            }
        }

        function validateSingleCell(input, r, c) {
            const val = input.value.trim().toUpperCase();
            const correctChar = crosswordGrid[r][c].char;

            // Feedback visual sutil al escribir
            if (val === '') {
                input.parentElement.classList.remove('bg-green-100', 'dark:bg-green-950/40', 'border-green-400', 'bg-red-50', 'dark:bg-red-950/20', 'border-red-400');
            } else if (val === correctChar) {
                input.parentElement.classList.remove('bg-red-50', 'dark:bg-red-950/20', 'border-red-400');
                input.parentElement.classList.add('bg-green-50', 'dark:bg-green-950/20', 'border-green-300', 'dark:border-green-800');
            } else {
                input.parentElement.classList.remove('bg-green-50', 'dark:bg-green-950/20', 'border-green-300');
                input.parentElement.classList.add('bg-red-50', 'dark:bg-red-950/25', 'border-red-300');
            }
        }

        function renderCrosswordClues() {
            const listAcross = document.getElementById('cluesAcross');
            const listDown = document.getElementById('cluesDown');

            listAcross.innerHTML = '';
            listDown.innerHTML = '';

            // Clasificar pistas
            crosswordPlacements.forEach(p => {
                const li = document.createElement('li');
                li.className = "p-1.5 hover:bg-slate-50 dark:hover:bg-slate-800 rounded-lg transition-colors flex items-start gap-2 leading-relaxed cursor-pointer";
                li.innerHTML = `<span class="font-bold text-blue-500">${p.num}.</span> <span class="text-slate-600 dark:text-slate-300">${p.clue}</span>`;

                // Al hacer clic en una pista, hacer foco en su primera celda
                li.onclick = () => {
                    const firstInput = document.querySelector(`input[data-r="${p.r}"][data-c="${p.c}"]`);
                    if (firstInput) {
                        firstInput.focus();
                        firstInput.select();
                    }
                };

                if (p.dir === 'across') {
                    listAcross.appendChild(li);
                } else {
                    listDown.appendChild(li);
                }
            });

            if (listAcross.children.length === 0) {
                listAcross.innerHTML = `<li class="text-xs text-slate-400 italic">Ninguna</li>`;
            }
            if (listDown.children.length === 0) {
                listDown.innerHTML = `<li class="text-xs text-slate-400 italic">Ninguna</li>`;
            }
        }

        // Navegación intuitiva con flechas del teclado dentro del crucigrama
        function navigateCrosswordKey(e, r, c) {
            let nextR = r;
            let nextC = c;

            // Encontrar la dirección lógica de la palabra actual bajo el cursor (Horizontal o Vertical)
            let isMovingHorizontal = true;
            const hasRightNeighbor = (c < crosswordGridWidth - 1 && !crosswordGrid[r][c+1].black);
            const hasLeftNeighbor = (c > 0 && !crosswordGrid[r][c-1].black);
            if (!hasRightNeighbor && !hasLeftNeighbor) {
                isMovingHorizontal = false;
            }

            switch (e.key) {
                case 'ArrowUp': nextR = r - 1; break;
                case 'ArrowDown': nextR = r + 1; break;
                case 'ArrowLeft': nextC = c - 1; break;
                case 'ArrowRight': nextC = c + 1; break;
                case 'Backspace':
                    // Si la celda está vacía, regresar a la anterior según la palabra lógica
                    if (e.target.value === '') {
                        const targetPrevInput = isMovingHorizontal 
                            ? document.querySelector(`input[data-r="${r}"][data-c="${c-1}"]`)
                            : document.querySelector(`input[data-r="${r-1}"][data-c="${c}"]`);
                        if (targetPrevInput) {
                            targetPrevInput.focus();
                            targetPrevInput.select();
                        }
                    } else {
                        // Si tiene una letra, limpiarla pero quedarse ahí
                        e.target.value = '';
                        validateSingleCell(e.target, r, c);
                    }
                    return;
                default:
                    // Al presionar cualquier carácter del alfabeto, saltar de inmediato a la siguiente casilla lógica
                    if (/^[a-zA-ZñÑ]$/.test(e.key)) {
                        setTimeout(() => {
                            const targetNextInput = isMovingHorizontal
                                ? document.querySelector(`input[data-r="${r}"][data-c="${c+1}"]`)
                                : document.querySelector(`input[data-r="${r+1}"][data-c="${c}"]`);
                            if (targetNextInput) {
                                targetNextInput.focus();
                                targetNextInput.select();
                            }
                        }, 10);
                    }
                    return;
            }

            const targetInput = document.querySelector(`input[data-r="${nextR}"][data-c="${nextC}"]`);
            if (targetInput) {
                e.preventDefault();
                targetInput.focus();
            }
        }

        function checkCrosswordWin() {
            let correct = true;
            let inputsFilled = 0;
            let totalInputs = 0;

            const inputs = document.querySelectorAll('#crucigramaGridContainer input');
            inputs.forEach(input => {
                totalInputs++;
                const r = parseInt(input.dataset.r);
                const c = parseInt(input.dataset.c);
                const val = input.value.trim().toUpperCase();

                if (val !== '') {
                    inputsFilled++;
                }

                // Validar contra la matriz de la solución generada
                if (val !== crosswordGrid[r][c].char) {
                    correct = false;
                }
            });

            // Si todas son correctas
            if (correct && inputsFilled === totalInputs) {
                document.getElementById('crosswordWinBanner').classList.remove('hidden');
                inputs.forEach(input => {
                    input.parentElement.classList.remove('bg-green-50');
                    input.parentElement.classList.add('bg-green-100', 'border-green-400', 'animate-pop');
                    input.disabled = true;
                });
                showToast("¡Felicidades! Crucigrama resuelto correctamente.", "success");
            }
        }

        // --- REINICIAR JUEGO ACTUAL ---
        function resetCurrentGame() {
            if (appMode === 'sopa') {
                // Sopa de Letras: Marcar todo como no encontrado
                sopaWords.forEach(w => w.found = false);
                renderSopaGrid();
                renderSopaWordsList();
                document.getElementById('winBanner').classList.add('hidden');
                showToast("Sopa de letras reiniciada", "info");
            } else {
                // Crucigrama: Limpiar inputs
                const inputs = document.querySelectorAll('#crucigramaGridContainer input');
                inputs.forEach(input => {
                    input.value = '';
                    input.disabled = false;
                    input.parentElement.classList.remove('bg-green-50', 'bg-green-100', 'border-green-300', 'border-green-400', 'bg-red-50', 'border-red-300');
                });
                document.getElementById('crosswordWinBanner').classList.add('hidden');
                showToast("Crucigrama reiniciado", "info");
            }
        }

    </script>
