<!DOCTYPE html>
<html lang="es" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Creador de Sopas de Letras y Crucigramas</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        customBlue: {
                            50: '#f0f7ff',
                            100: '#e0effe',
                            500: '#3b82f6',
                            600: '#2563eb',
                            700: '#1d4ed8',
                        }
                    }
                }
            }
        }
    </script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }
        /* Desactivar scroll al arrastrar en la sopa de letras en móviles */
        .no-scroll {
            touch-action: none;
            overflow: hidden;
        }
        /* Grid de Sopa de Letras optimizado */
        .sopa-grid {
            user-select: none;
            touch-action: none;
        }
        /* Ocultar flechas de inputs de número */
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        /* Animaciones para ganar */
        @keyframes pop {
            0% { transform: scale(1); }
            50% { transform: scale(1.1); }
            100% { transform: scale(1); }
        }
        .animate-pop {
            animation: pop 0.3s ease-in-out;
        }
    </style>
</head>
<body class="bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-100 min-h-full flex flex-col transition-colors duration-300">

    <!-- CABECERA -->
    <header class="w-full bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shadow-sm sticky top-0 z-40">
        <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-gradient-to-tr from-blue-500 to-indigo-600 rounded-xl text-white shadow-md">
                    <i data-lucide="puzzle" class="w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="font-extrabold text-lg md:text-xl bg-gradient-to-r from-blue-600 to-indigo-500 dark:from-blue-400 dark:to-indigo-300 bg-clip-text text-transparent">
                        MenteÁgil
                    </h1>
                    <p class="text-[10px] md:text-xs text-slate-400 dark:text-slate-500 font-medium tracking-wide uppercase">Generador de Pasatiempos</p>
                </div>
            </div>

            <!-- Botones derecho -->
            <div class="flex items-center gap-2">
                <!-- Toggle de Modo Oscuro -->
                <button id="themeToggle" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 hover:bg-slate-50 dark:hover:bg-slate-900 transition-all text-slate-500 dark:text-slate-400" aria-label="Cambiar Tema">
                    <i data-lucide="sun" id="sunIcon" class="w-5 h-5 hidden"></i>
                    <i data-lucide="moon" id="moonIcon" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- SELECTOR DE PASATIEMPOS (TABS) -->
    <div class="w-full max-w-7xl mx-auto px-4 mt-6">
        <div class="bg-slate-200/60 dark:bg-slate-900 p-1.5 rounded-2xl flex gap-1.5 shadow-inner">
            <button onclick="switchAppMode('sopa')" id="tab-sopa" class="flex-1 py-3 px-4 rounded-xl text-sm font-bold transition-all flex items-center justify-center gap-2.5 bg-white dark:bg-slate-800 text-blue-600 dark:text-blue-400 shadow-sm">
                <i data-lucide="grid" class="w-4 h-4"></i>
                <span>Sopa de Letras</span>
            </button>
            <button onclick="switchAppMode('crucigrama')" id="tab-crucigrama" class="flex-1 py-3 px-4 rounded-xl text-sm font-bold transition-all flex items-center justify-center gap-2.5 text-slate-500 dark:text-slate-400 hover:text-slate-800 dark:hover:text-slate-200">
                <i data-lucide="table-properties" class="w-4 h-4"></i>
                <span>Crucigrama</span>
            </button>
        </div>
    </div>

    <!-- NOTIFICACIONES DE ACCIÓN (TOAST) -->
    <div id="toastNotification" class="fixed bottom-6 right-6 z-50 transform translate-y-20 opacity-0 pointer-events-none transition-all duration-300 max-w-sm w-full bg-slate-900 text-white dark:bg-white dark:text-slate-900 px-4 py-3.5 rounded-2xl shadow-2xl flex items-center gap-3 border border-slate-800/20">
        <i data-lucide="info" id="toastIcon" class="w-5 h-5 text-blue-400 shrink-0"></i>
        <p id="toastMessage" class="text-xs font-semibold leading-relaxed"></p>
    </div>

    <!-- CONTENEDOR PRINCIPAL -->
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 py-6 flex flex-col lg:flex-row gap-6 items-stretch">
        
        <!-- PANEL DE CONFIGURACIÓN (Izquierda) -->
        <div class="w-full lg:w-96 flex flex-col gap-5 shrink-0">
            
            <!-- TARJETA: PLANTILLAS TEMÁTICAS -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-800/60 rounded-3xl p-5 shadow-sm">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-3 flex items-center gap-2">
                    <i data-lucide="sparkles" class="w-4 h-4 text-amber-500"></i>
                    Temas Rápidos de Prueba
                </h3>
                <div class="grid grid-cols-2 gap-2">
                    <button onclick="loadTemplate('animales')" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500 bg-slate-50/50 dark:bg-slate-950/20 text-xs font-semibold text-left transition-all active:scale-95 flex items-center gap-2">
                        <span>🦁</span> Animales
                    </button>
                    <button onclick="loadTemplate('paises')" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500 bg-slate-50/50 dark:bg-slate-950/20 text-xs font-semibold text-left transition-all active:scale-95 flex items-center gap-2">
                        <span>🌎</span> Países
                    </button>
                    <button onclick="loadTemplate('frutas')" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500 bg-slate-50/50 dark:bg-slate-950/20 text-xs font-semibold text-left transition-all active:scale-95 flex items-center gap-2">
                        <span>🍎</span> Frutas
                    </button>
                    <button onclick="loadTemplate('tech')" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500 bg-slate-50/50 dark:bg-slate-950/20 text-xs font-semibold text-left transition-all active:scale-95 flex items-center gap-2">
                        <span>💻</span> Tecnología
                    </button>
                </div>
            </div>

            <!-- TARJETA: CONFIGURACIÓN DINÁMICA -->
            <div class="bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-800/60 rounded-3xl p-5 shadow-sm flex-1 flex flex-col justify-between">
                
                <!-- Sección superior -->
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <h2 class="text-base font-bold text-slate-800 dark:text-white flex items-center gap-2">
                            <i data-lucide="sliders" class="w-5 h-5 text-blue-500"></i>
                            Cargar Datos
                        </h2>
                        <span id="modeBadge" class="text-[10px] font-extrabold px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 dark:bg-blue-950/40 dark:text-blue-400 uppercase tracking-wider">Sopa de Letras</span>
                    </div>

                    <!-- Config Sopa de Letras -->
                    <div id="config-sopa" class="space-y-4">
                        <!-- Tamaño de la Sopa -->
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Tamaño del Tablero</label>
                            <div class="grid grid-cols-3 gap-2">
                                <button onclick="setGridSize(10)" id="size-10" class="py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold text-xs transition-all active:scale-95">10x10</button>
                                <button onclick="setGridSize(12)" id="size-12" class="py-2 rounded-xl border-2 border-blue-500 bg-blue-50/50 dark:bg-blue-950/20 text-blue-600 dark:text-blue-400 font-bold text-xs transition-all active:scale-95">12x12</button>
                                <button onclick="setGridSize(15)" id="size-15" class="py-2 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 font-bold text-xs transition-all active:scale-95">15x15</button>
                            </div>
                        </div>

                        <!-- Dificultad -->
                        <div class="space-y-1.5">
                            <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Direcciones de Letras</label>
                            <div class="grid grid-cols-2 gap-2">
                                <button onclick="setDifficulty('easy')" id="diff-easy" class="py-2 px-3 rounded-xl border-2 border-blue-500 bg-blue-50/50 dark:bg-blue-950/20 text-blue-600 dark:text-blue-400 font-bold text-xs text-left transition-all flex items-center justify-between">
                                    <span>Fácil</span>
                                    <span class="text-[9px] bg-blue-100 dark:bg-blue-900 px-1.5 py-0.5 rounded">➡️ ⬇️</span>
                                </button>
                                <button onclick="setDifficulty('hard')" id="diff-hard" class="py-2 px-3 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-950 text-slate-500 dark:text-slate-400 font-bold text-xs text-left transition-all flex items-center justify-between">
                                    <span>Difícil</span>
                                    <span class="text-[9px] bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded">↗️ ↙️ 🔄</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Config Crucigrama -->
                    <div id="config-crucigrama" class="space-y-4 hidden">
                        <p class="text-xs text-slate-400 leading-relaxed">
                            Carga tus palabras y las pistas/definiciones asociadas en el listado de abajo. El sistema intentará cruzarlas automáticamente de la mejor manera.
                        </p>
                    </div>

                    <!-- Entrada de Palabras Dinámicas -->
                    <div class="space-y-2">
                        <div class="flex justify-between items-center">
                            <label class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider" id="listTitleLabel">Palabras / Pistas</label>
                            <button onclick="addNewWordInput()" class="text-xs text-blue-500 hover:text-blue-600 dark:hover:text-blue-400 font-bold flex items-center gap-1">
                                <i data-lucide="plus" class="w-3.5 h-3.5"></i> Añadir Palabra
                            </button>
                        </div>
                        
                        <!-- Lista Escroleable de Inputs -->
                        <div id="wordInputsContainer" class="space-y-2 max-h-[220px] md:max-h-[280px] overflow-y-auto pr-1">
                            <!-- Los inputs se generan dinámicamente aquí -->
                        </div>
                    </div>
                </div>

                <!-- Botón Generador -->
                <div class="pt-5 border-t border-slate-100 dark:border-slate-800/80 mt-4">
                    <button onclick="generateGame()" class="w-full py-4 px-4 bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 active:scale-95 transition-all text-white font-bold rounded-2xl shadow-lg shadow-blue-500/25 flex items-center justify-center gap-2">
                        <i data-lucide="refresh-cw" class="w-5 h-5"></i>
                        <span>Construir Tablero</span>
                    </button>
                </div>

            </div>

        </div>

        <!-- ÁREA DEL JUEGO INTERACTIVO (Derecha) -->
        <div class="flex-1 bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-800/60 rounded-3xl p-4 md:p-6 shadow-sm flex flex-col justify-between min-h-[450px]">
            
            <!-- HEADER DEL JUEGO -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pb-4 border-b border-slate-100 dark:border-slate-800">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl bg-blue-50 dark:bg-blue-950/40 flex items-center justify-center text-blue-500">
                        <i id="gameIcon" data-lucide="grid" class="w-5 h-5"></i>
                    </div>
                    <div>
                        <h2 id="gameTitle" class="font-bold text-base md:text-lg text-slate-800 dark:text-white">Sopa de Letras Interactiva</h2>
                        <p id="gameSubtitle" class="text-xs text-slate-400 dark:text-slate-500">Selecciona arrastrando sobre las letras para encontrar las palabras</p>
                    </div>
                </div>

                <!-- Controles de pantalla de juego -->
                <div class="flex items-center gap-2 self-end sm:self-auto">
                    <!-- Botón Imprimir/Exportar -->
                    <button onclick="window.print()" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 flex items-center gap-2 text-xs font-bold active:scale-95 transition-all">
                        <i data-lucide="printer" class="w-4 h-4"></i>
                        <span>Imprimir</span>
                    </button>
                    <!-- Botón Limpiar/Reiniciar -->
                    <button onclick="resetCurrentGame()" class="p-2.5 rounded-xl border border-slate-200 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-400 flex items-center gap-2 text-xs font-bold active:scale-95 transition-all">
                        <i data-lucide="rotate-ccw" class="w-4 h-4"></i>
                        <span>Reiniciar</span>
                    </button>
                </div>
            </div>

            <!-- CONTENEDOR CENTRAL: CUADRÍCULA E INTERFACES -->
            <div class="flex-1 flex flex-col lg:flex-row gap-6 items-center lg:items-stretch justify-center py-6">
                
                <!-- SUB-SECCIÓN: VISTA JUEGO SOPA DE LETRAS -->
                <div id="game-sopa-view" class="w-full max-w-[340px] md:max-w-[420px] aspect-square flex items-center justify-center relative">
                    <div id="sopaGridContainer" class="sopa-grid w-full h-full grid gap-1 p-2 bg-slate-100 dark:bg-slate-950 rounded-2xl border border-slate-200/50 dark:border-slate-800/80">
                        <!-- Las celdas se insertan aquí vía JS -->
                    </div>
                </div>

                <!-- SUB-SECCIÓN: VISTA JUEGO CRUCIGRAMA -->
                <div id="game-crucigrama-view" class="w-full max-w-[440px] flex-col items-center justify-center hidden">
                    <!-- Grilla del Crucigrama -->
                    <div id="crucigramaGridContainer" class="grid gap-[2px] p-2 bg-slate-200 dark:bg-slate-950 rounded-2xl border border-slate-300 dark:border-slate-800 w-full overflow-auto max-h-[380px] max-w-full justify-center">
                        <!-- Celdas del crucigrama se generan aquí -->
                    </div>
                </div>

                <!-- PANEL LATERAL DE PALABRAS / PISTAS -->
                <div class="w-full lg:w-64 shrink-0 flex flex-col justify-between border-t lg:border-t-0 lg:border-l border-slate-100 dark:border-slate-800/80 pt-5 lg:pt-0 lg:pl-5">
                    
                    <!-- Sopa Letras: Lista de palabras -->
                    <div id="list-sopa-panel" class="space-y-3 h-full flex flex-col justify-between">
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <span class="text-xs font-bold text-slate-400 dark:text-slate-500 uppercase tracking-wider">Palabras por buscar</span>
                                <span id="wordProgress" class="text-xs font-extrabold text-blue-500">0/0</span>
                            </div>
                            <!-- Contenedor de palabras -->
                            <div id="sopaWordsList" class="flex flex-wrap lg:flex-col gap-2 max-h-[160px] lg:max-h-[320px] overflow-y-auto">
                                <!-- Generadas por JS -->
                            </div>
                        </div>

                        <!-- Felicitación oculta -->
                        <div id="winBanner" class="p-4 bg-green-50 dark:bg-green-950/20 text-green-700 dark:text-green-300 border border-green-100 dark:border-green-900/30 rounded-2xl hidden flex-col items-center text-center gap-1.5 animate-bounce">
                            <span class="text-lg">🎉 ¡Felicidades! 🎉</span>
                            <span class="text-[11px] font-semibold">Has encontrado todas las palabras con éxito.</span>
                        </div>
                    </div>

                    <!-- Crucigrama: Lista de pistas -->
                    <div id="list-crucigrama-panel" class="space-y-4 hidden h-full flex flex-col justify-between">
                        <div class="flex-1 overflow-y-auto space-y-3 pr-1 max-h-[250px] lg:max-h-[350px]">
                            <!-- Horizontales -->
                            <div>
                                <h4 class="text-xs font-bold text-blue-500 uppercase tracking-wider mb-1.5 flex items-center gap-1">
                                    <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i> Horizontales
                                </h4>
                                <ul id="cluesAcross" class="space-y-1.5 text-xs text-slate-600 dark:text-slate-300">
                                    <!-- Dinámico -->
                                </ul>
                            </div>
                            <!-- Verticales -->
                            <div class="pt-2 border-t border-slate-100 dark:border-slate-800/80">
                                <h4 class="text-xs font-bold text-indigo-500 uppercase tracking-wider mb-1.5 flex items-center gap-1">
                                    <i data-lucide="arrow-down" class="w-3.5 h-3.5"></i> Verticales
                                </h4>
                                <ul id="cluesDown" class="space-y-1.5 text-xs text-slate-600 dark:text-slate-300">
                                    <!-- Dinámico -->
                                </ul>
                            </div>
                        </div>

                        <!-- Banner de Victoria Crucigrama -->
                        <div id="crosswordWinBanner" class="p-4 bg-green-50 dark:bg-green-950/20 text-green-700 dark:text-green-300 border border-green-100 dark:border-green-900/30 rounded-2xl hidden flex-col items-center text-center gap-1.5">
                            <span class="text-lg">🏆 ¡Resuelto! 🏆</span>
                            <span class="text-[11px] font-semibold">Has rellenado el crucigrama correctamente.</span>
                        </div>
                    </div>

                </div>

            </div>

        </div>

    </main>

    <!-- FOOTER -->
    <footer class="w-full text-center py-5 text-xs text-slate-400 dark:text-slate-600 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800 mt-6 shrink-0">
        <p>MenteÁgil Generador • Diseñado para dispositivos móviles y de escritorio</p>
    </footer>

    <!-- LÓGICA DEL JUEGO -->
    <script>
        // Inicializar iconos de Lucide
        lucide.createIcons();

        // --- VARIABLES DE ESTADO GLOBAL ---
        let appMode = 'sopa'; // 'sopa' o 'crucigrama'
        let currentGridSize = 12; 
        let currentDifficulty = 'easy'; // 'easy' o 'hard'
        
        // Sopa de letras
        let sopaWords = []; // { text, found, cells: [{r, c}] }
        let sopaGrid = [];  // Matriz de letras
        let isSelecting = false;
        let selectStartCell = null;
        let selectEndCell = null;
        let selectedCellsList = [];

        // Crucigrama
        let crosswordWords = []; // { word, clue }
        let crosswordGrid = [];  // Matriz de celdas
        let crosswordGridWidth = 13;
        let crosswordGridHeight = 13;
        let crosswordPlacements = []; // { word, r, c, dir, num }

        // Plantillas Temáticas de Prueba
        const templates = {
            animales: [
                { word: 'LEON', clue: 'El rey de la selva' },
                { word: 'TIGRE', clue: 'Felino de pelaje rayado' },
                { word: 'CEBRA', clue: 'Equino de rayas blancas y negras' },
                { word: 'JIRAFA', clue: 'Animal terrestre más alto' },
                { word: 'DELFIN', clue: 'Mamífero marino inteligente' },
                { word: 'PANDA', clue: 'Oso que come bambú' }
            ],
            paises: [
                { word: 'MEXICO', clue: 'Cuna del mariachi y el taco' },
                { word: 'ESPAÑA', clue: 'País de la península ibérica' },
                { word: 'BRASIL', clue: 'País del carnaval y el Amazonas' },
                { word: 'ITALIA', clue: 'País con forma de bota' },
                { word: 'FRANCIA', clue: 'Hogar de la Torre Eiffel' },
                { word: 'JAPON', clue: 'Tierra del sol naciente' }
            ],
            frutas: [
                { word: 'MANZANA', clue: 'Roja o verde, famosa por Newton' },
                { word: 'PLATANO', clue: 'Fruta amarilla rica en potasio' },
                { word: 'NARANJA', clue: 'Cítrico rico en Vitamina C' },
                { word: 'SANDIA', clue: 'Grande, verde por fuera y roja por dentro' },
                { word: 'LIMON', clue: 'Muy ácido y de color amarillo o verde' },
                { word: 'MANGO', clue: 'Tropical, dulce y de pulpa carnosa' }
            ],
            tech: [
                { word: 'CELULAR', clue: 'Dispositivo móvil personal' },
                { word: 'TECLADO', clue: 'Periférico usado para escribir' },
                { word: 'ROUTER', clue: 'Distribuye la señal de internet inalámbrica' },
                { word: 'PANTALLA', clue: 'Muestra visualmente la información' },
                { word: 'CODIGO', clue: 'Instrucciones lógicas para programar' },
                { word: 'RATON', clue: 'Dispositivo apuntador de computadora' }
            ]
        };

        // Al iniciar la ventana
        window.onload = function() {
            loadTemplate('animales');
            setupTheme();
        }

        // --- MODO OSCURO ---
        function setupTheme() {
            const themeToggle = document.getElementById('themeToggle');
            const sunIcon = document.getElementById('sunIcon');
            const moonIcon = document.getElementById('moonIcon');

            if (localStorage.getItem('theme') === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                document.documentElement.classList.add('dark');
                sunIcon.classList.remove('hidden');
                moonIcon.classList.add('hidden');
            } else {
                document.documentElement.classList.remove('dark');
                sunIcon.classList.add('hidden');
                moonIcon.classList.remove('hidden');
            }

            themeToggle.addEventListener('click', () => {
                if (document.documentElement.classList.contains('dark')) {
                    document.documentElement.classList.remove('dark');
                    localStorage.setItem('theme', 'light');
                    sunIcon.classList.add('hidden');
                    moonIcon.classList.remove('hidden');
                } else {
                    document.documentElement.classList.add('dark');
                    localStorage.setItem('theme', 'dark');
                    sunIcon.classList.remove('hidden');
                    moonIcon.classList.add('hidden');
                }
            });
        }

        // --- SISTEMA DE TOAST DE NOTIFICACIÓN ---
        function showToast(message, type = 'info') {
            const toast = document.getElementById('toastNotification');
            const toastMsg = document.getElementById('toastMessage');
            const toastIcon = document.getElementById('toastIcon');

            toastMsg.textContent = message;

